# ─── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Clouts

# ─── Supabase ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ─── Auth (NextAuth v5) ────────────────────────────
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Upstash Redis ─────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_QSTASH_TOKEN=
UPSTASH_QSTASH_URL=

# ─── AI ────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Inngest ───────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Email ─────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@clouts.com
LOOPS_API_KEY=

# ─── Stripe ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=
# /pricing page tiers (Starter/Growth/Enterprise) — each needs a Stripe
# Price configured with a default trial via the Price's subscription
# trial settings, or pass trial_period_days at checkout (already wired
# in api/billing/checkout/route.ts via PLANS[plan].trialDays).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_YEARLY=
# Enterprise trials bill at the Growth rate until sales adjusts the
# subscription to the negotiated custom price. Falls back to the Growth
# price ID above if these are left unset.
STRIPE_PRICE_ENTERPRISE_TRIAL_MONTHLY=
STRIPE_PRICE_ENTERPRISE_TRIAL_YEARLY=

# ─── Mux (Video) ───────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
NEXT_PUBLIC_MUX_ENV_KEY=

# ─── AssemblyAI (Captions) ─────────────────────────
ASSEMBLYAI_API_KEY=

# ─── Cloudflare R2 (Storage) ───────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clouts-media
NEXT_PUBLIC_R2_PUBLIC_URL=

# ─── BrightData (Scraping) ─────────────────────────
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=

# ─── Monitoring ────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
AXIOM_TOKEN=
AXIOM_DATASET=clouts-logs
